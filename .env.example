# Copy to .env and fill in. .env is gitignored — never committed.
# Every key is optional: without one, that panel reports the missing key and
# the rest of the app keeps working. See INTEGRATIONS.md for the full guide.

# Tavily (live news/developments): free key at https://app.tavily.com  ->  tvly-...
# The only metered service — 1 credit per uncached crisis click.
TAVILY_API_KEY=

# ACLED (structured conflict timeline): register at https://acleddata.com/register
# ACLED moved to OAuth2 in 2025 — this is your ACCOUNT PASSWORD, not an API key.
# The old ACLED_API_KEY is no longer read by server.py and can be deleted.
ACLED_EMAIL=
ACLED_PASSWORD=

# NASA Earth Imagery (Landsat snapshot per location): free key at https://api.nasa.gov
NASA_API_KEY=

# --- Local API protection (all optional; defaults are safe) ---
# Bind address. Loopback-only by default; set 0.0.0.0 to expose on the LAN
# (this makes the credit-spending /api/detail reachable by any host there).
HOST=127.0.0.1
# Comma-separated CORS allowlist. Default: http://localhost:8000,http://127.0.0.1:8000
ALLOWED_ORIGINS=
# Per-IP requests/minute to /api/* (0 = unlimited). Default 30.
RATE_LIMIT_PER_MIN=30
# Leave empty for normal local use. If set, every /api/* call must send the
# value as an X-API-Token header or ?token= query param.
EII_API_TOKEN=
