# Copy to .env and fill in. .env is gitignored — never committed.
# Tavily (live news/developments): free key at https://app.tavily.com  ->  tvly-...
TAVILY_API_KEY=
# ACLED (structured conflict timeline): register at https://developer.acleddata.com
ACLED_API_KEY=
ACLED_EMAIL=

# --- Local API protection (all optional; defaults are safe) ---
# Bind address. Loopback-only by default; set 0.0.0.0 to expose on the LAN
# (this makes the credit-spending /api/detail reachable by any host there).
HOST=127.0.0.1
# Comma-separated CORS allowlist. Default: http://localhost:8000,http://127.0.0.1:8000
ALLOWED_ORIGINS=
# Per-IP requests/minute to /api/* (0 = unlimited). Default 30.
RATE_LIMIT_PER_MIN=30
# Leave empty for normal local use. If set, every /api/* call must send the
# value as an X-API-Token header or ?token= query param.
EII_API_TOKEN=
